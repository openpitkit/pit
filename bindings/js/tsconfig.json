{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "npm:@openpit/engine": ["./src-ts/index.ts"],
      "@openpit/engine": ["./src-ts/index.ts"],
      "@openpit/engine/param": ["./src-ts/param/index.ts"],
      "@openpit/engine/core": ["./src-ts/core/index.ts"],
      "@openpit/engine/model": ["./src-ts/model/index.ts"],
      "@openpit/engine/pretrade": ["./src-ts/pretrade/index.ts"],
      "@openpit/engine/pretrade/policies": [
        "./src-ts/pretrade/policies/index.ts"
      ],
      "@openpit/engine/marketdata": ["./src-ts/marketdata/index.ts"],
      "@openpit/engine/reject": ["./src-ts/reject/index.ts"],
      "@openpit/engine/accountadjustment": [
        "./src-ts/accountadjustment/index.ts"
      ],
      "@openpit/engine/accounts": ["./src-ts/accounts/index.ts"],
      "@openpit/engine/tx": ["./src-ts/tx/index.ts"]
    }
  },
  "include": ["src-ts/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
